# Lemma SDK
LEMMA_API_KEY=your_lemma_api_key_here

# Groq (LLM inference)
GROQ_API_KEY=your_groq_api_key_here

# API server
PORT=3001

# Web (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Lemma & AgentBox Config
agentbox_api_key=your_agentbox_api_key_here
LEMMA_DEFAULT_MODEL_TYPE=openai_compat
LEMMA_OPENAI_API_KEY=your_groq_api_key_here
LEMMA_OPENAI_BASE_URL=https://api.groq.com/openai/v1
LEMMA_OPENAI_DEFAULT_MODEL=llama-3.3-70b-versatile

# Google Sign-In Integration
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your_google_client_id_here"
